---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="페이지를 찾을 수 없습니다"
  description="요청하신 페이지를 찾을 수 없습니다."
  path="/404"
>
  <section class="notfound">
    <h1>404</h1>
    <p>요청하신 페이지를 찾을 수 없습니다.</p>
    <p><a href="/">홈으로 돌아가기</a></p>
  </section>
</BaseLayout>

<style>
  .notfound {
    text-align: center;
    padding: 48px 0;
  }
  .notfound h1 {
    font-size: 3rem;
    margin: 0;
    color: var(--accent);
  }
</style>
