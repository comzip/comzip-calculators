---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import { calculators } from '../../data/calculators';

const meta = calculators.find((c) => c.slug === 'unemployment-benefit-calculator')!;
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  path={`/calculators/${meta.slug}`}
>
  <h1>{meta.title}</h1>
  <p class="note">
    이직일과 이직 전 3개월 급여, 나이·고용보험 가입기간을 입력하면
    <strong>실업급여(구직급여)</strong> 예상 수급액을 계산합니다.
  </p>

  <form class="calc-form" id="ui-form">
    <label>
      이직일 (퇴사일)
      <input type="date" id="resignDate" name="resignDate" required />
    </label>

    <label>
      이직일 이전 3개월 급여 총액 (세전, 원)
      <span class="hint">기본급+제수당 합계. 예: 9000000</span>
      <input
        type="number"
        id="threeMonthWage"
        name="threeMonthWage"
        min="0"
        step="any"
        placeholder="예: 9000000"
        required
      />
      <span class="amount-preview" id="threeMonthWage-preview" aria-live="polite"></span>
    </label>

    <fieldset class="method-toggle">
      <legend>연령</legend>
      <label class="method-option">
        <input type="radio" name="ageGroup" value="50세 미만" checked />
        <span>50세 미만</span>
      </label>
      <label class="method-option">
        <input type="radio" name="ageGroup" value="50세 이상 또는 장애인" />
        <span>50세 이상 또는 장애인</span>
      </label>
    </fieldset>

    <label>
      고용보험 가입기간
      <select id="insuredPeriod">
        <option value="1년 미만">1년 미만</option>
        <option value="1~3년" selected>1년 이상 ~ 3년 미만</option>
        <option value="3~5년">3년 이상 ~ 5년 미만</option>
        <option value="5~10년">5년 이상 ~ 10년 미만</option>
        <option value="10년 이상">10년 이상</option>
      </select>
    </label>

    <button class="btn" type="submit">계산하기</button>
  </form>

  <p class="note" id="error-msg" role="alert"></p>

  <div class="result-box hidden" id="result" aria-live="polite">
    <p class="note" id="clamp-note" style="margin-top:0;"></p>
    <div class="result-grid">
      <div class="result-item">
        <span class="label">총 예상 수급액</span>
        <span class="value"><span id="total-benefit">-</span></span>
      </div>
      <div class="result-item">
        <span class="label">1일 구직급여액</span>
        <span class="value"><span id="daily-benefit">-</span></span>
      </div>
    </div>

    <table class="breakdown">
      <caption class="note" style="text-align:left;margin-bottom:6px;">
        산출 내역
      </caption>
      <tbody>
        <tr>
          <td>평균임금 산정기간</td>
          <td id="row-period">-</td>
        </tr>
        <tr>
          <td>1일 평균임금</td>
          <td id="row-avg-wage">-</td>
        </tr>
        <tr>
          <td>구직급여일액(상하한 적용 전)</td>
          <td id="row-raw">-</td>
        </tr>
        <tr>
          <td>구직급여일액(상하한 적용 후)</td>
          <td id="row-daily">-</td>
        </tr>
        <tr>
          <td>소정급여일수</td>
          <td id="row-days">-</td>
        </tr>
        <tr class="total">
          <td>총 예상 수급액</td>
          <td id="row-total">-</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="disclaimer">
    본 계산 결과는 <strong>단순화된 추정치</strong>입니다. 실업급여는
    비자발적 이직(권고사직·계약만료·해고 등)이 원칙이며, 자발적 퇴사는
    정당한 사유가 인정되는 예외적인 경우에만 수급 대상이 됩니다.
    피보험단위기간(이직일 이전 18개월간 180일 이상 근무) 등 다른 요건도
    충족해야 합니다. 상한액·하한액은 매년 바뀌므로 정확한 금액은
    고용24(work24.go.kr) 또는 관할 고용센터에서 확인하세요.
  </div>

  <AdSlot />

  <section class="faq">
    <h2>자주 묻는 질문</h2>

    <details>
      <summary>실업급여는 얼마나 받나요?</summary>
      <p>
        <strong>구직급여일액 = 이직 전 평균임금 × 60%</strong>로 계산하며,
        여기에 하한액·상한액이 적용됩니다(2026년 기준 하한 66,048원,
        상한 68,100원). 이 일액에 <strong>소정급여일수</strong>를 곱한
        금액이 총 예상 수급액입니다.
      </p>
    </details>

    <details>
      <summary>소정급여일수는 어떻게 정해지나요?</summary>
      <p>
        이직 당시 <strong>나이</strong>와 <strong>고용보험 가입
        기간</strong>에 따라 120일~270일로 차등됩니다. 나이가 많고
        가입기간이 길수록 더 오래 받을 수 있습니다.
      </p>
    </details>

    <details>
      <summary>아무나 실업급여를 받을 수 있나요?</summary>
      <p>
        아닙니다. 원칙적으로 <strong>비자발적으로 이직</strong>했고,
        <strong>이직일 이전 18개월간 피보험단위기간이 180일
        이상</strong>이며, 근로 의사와 능력이 있음에도 취업하지 못한
        상태에서 적극적으로 구직활동을 해야 합니다. 자발적 퇴사도 임금
        체불, 괴롭힘 등 정당한 사유가 인정되면 예외적으로 대상이 될 수
        있습니다.
      </p>
    </details>

    <details>
      <summary>왜 이 계산기 결과가 실제 수급액과 다를 수 있나요?</summary>
      <p>
        상한액·하한액은 최저임금 등에 따라 매년 바뀌고, 실제 평균임금
        산정 시 상여금·연차수당 포함 여부 등 세부 규칙이 있습니다. 이
        계산기는 이직 전 3개월 급여만으로 계산한 참고용 추정치입니다.
      </p>
    </details>
  </section>
</BaseLayout>

<script>
  import { calculateUnemploymentBenefit } from '../../lib/unemploymentBenefitCalculator';
  import type {
    AgeGroup,
    InsuredPeriod,
  } from '../../lib/unemploymentBenefitCalculator';
  import { formatKoreanWon } from '../../lib/formatKoreanWon';

  const form = document.getElementById('ui-form') as HTMLFormElement;
  const result = document.getElementById('result') as HTMLDivElement;
  const errorMsg = document.getElementById('error-msg') as HTMLParagraphElement;

  const wageInput = document.getElementById('threeMonthWage') as HTMLInputElement;
  const wagePreview = document.getElementById('threeMonthWage-preview') as HTMLSpanElement;
  wageInput.addEventListener('input', () => {
    const value = Number(wageInput.value);
    wagePreview.textContent = value > 0 ? formatKoreanWon(value) : '';
  });

  const won = new Intl.NumberFormat('ko-KR', {
    style: 'currency',
    currency: 'KRW',
    maximumFractionDigits: 0,
  });
  const setWon = (id: string, value: number) => {
    const el = document.getElementById(id);
    if (el) el.textContent = won.format(Math.round(value));
  };

  form.addEventListener('submit', (event) => {
    event.preventDefault();
    errorMsg.textContent = '';

    const resignDate = (document.getElementById('resignDate') as HTMLInputElement).value;
    const threeMonthWage = Number(wageInput.value);
    const ageGroup = (
      form.querySelector('input[name="ageGroup"]:checked') as HTMLInputElement
    ).value as AgeGroup;
    const insuredPeriod = (
      document.getElementById('insuredPeriod') as HTMLSelectElement
    ).value as InsuredPeriod;

    if (!resignDate) {
      result.classList.add('hidden');
      errorMsg.textContent = '이직일을 입력해 주세요.';
      return;
    }
    if (!threeMonthWage || threeMonthWage <= 0) {
      result.classList.add('hidden');
      errorMsg.textContent = '이직일 이전 3개월 급여 총액을 올바르게 입력해 주세요.';
      return;
    }

    const r = calculateUnemploymentBenefit({
      threeMonthWage,
      resignDate,
      ageGroup,
      insuredPeriod,
    });

    setWon('total-benefit', r.totalBenefit);
    setWon('daily-benefit', r.dailyBenefit);
    (document.getElementById('row-period') as HTMLElement).textContent = `${r.periodDays}일`;
    setWon('row-avg-wage', r.averageDailyWage);
    setWon('row-raw', r.rawDailyBenefit);
    setWon('row-daily', r.dailyBenefit);
    (document.getElementById('row-days') as HTMLElement).textContent = `${r.benefitDays}일`;
    setWon('row-total', r.totalBenefit);

    const clampNote = document.getElementById('clamp-note') as HTMLParagraphElement;
    if (r.clampedToLower) {
      clampNote.textContent = '※ 계산된 금액이 하한액보다 낮아 하한액이 적용됐습니다.';
    } else if (r.clampedToUpper) {
      clampNote.textContent = '※ 계산된 금액이 상한액보다 높아 상한액이 적용됐습니다.';
    } else {
      clampNote.textContent = '';
    }

    result.classList.remove('hidden');
  });
</script>
