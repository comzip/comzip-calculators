---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { categoryOrder, calculatorsByCategory, categoryLabels } from '../../data/calculators';
---

<BaseLayout title="Comzip Calculators" path="/" lang="en">
  <section class="intro">
    <h1>Everyday Calculators</h1>
    <p>
      Comzip Calculators brings together the tools you actually reach for —
      age, salary, loans, taxes, and more — all in one free site. No sign-up,
      no installation: everything runs in your browser, and we keep adding more.
    </p>
  </section>

  {
    categoryOrder.map((category) => {
      const items = calculatorsByCategory(category);
      if (items.length === 0) return null;
      return (
        <section class="category">
          <h2>{categoryLabels[category].en}</h2>
          <div class="card-grid">
            {items.map((calculator) => (
              <CalculatorCard calculator={calculator} lang="en" />
            ))}
          </div>
        </section>
      );
    })
  }
</BaseLayout>

<style>
  .intro h1 {
    font-size: 1.6rem;
    margin: 8px 0 12px;
  }
  .intro p {
    color: var(--text-muted);
  }
  .category {
    margin-top: 32px;
  }
  .category h2 {
    font-size: 1.2rem;
    border-left: 4px solid var(--accent);
    padding-left: 10px;
    margin-bottom: 16px;
  }
  .card-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  }
</style>
