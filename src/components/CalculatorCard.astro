---
import type { Calculator } from '../data/calculators';
import type { Lang } from '../i18n/ui';

export interface Props {
  calculator: Calculator;
  lang?: Lang;
}

const { calculator, lang = 'ko' } = Astro.props;
const href = lang === 'en' ? `/en/calculators/${calculator.slug}` : `/calculators/${calculator.slug}`;
const title = lang === 'en' ? calculator.titleEn : calculator.title;
const description = lang === 'en' ? calculator.descriptionEn : calculator.description;
---

<a class="calc-card" href={href}>
  <h3>{title}</h3>
  <p>{description}</p>
</a>

<style>
  .calc-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px;
    background: var(--bg);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.15s ease,
      transform 0.15s ease;
  }
  .calc-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .calc-card h3 {
    margin: 0 0 6px;
    font-size: 1.05rem;
    color: var(--accent-dark);
  }
  .calc-card p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
</style>
