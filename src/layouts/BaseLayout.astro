---
import { calculators } from '../data/calculators';

export interface Props {
  title: string;
  description?: string;
  /** Path of the current page, used to build canonical / OG url. */
  path?: string;
}

const {
  title,
  description = '만나이, 연봉 실수령액 등 일상에 필요한 계산기를 모아둔 무료 계산기 허브입니다.',
  path = '/',
} = Astro.props;

const siteName = '계산기 허브';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
// Astro.site comes from `site` in astro.config.mjs.
const canonicalURL = Astro.site ? new URL(path, Astro.site).href : path;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="ko_KR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand">계산기 허브</a>
        <nav class="site-nav" aria-label="주요 계산기">
          <ul>
            {
              calculators.map((c) => (
                <li>
                  <a href={`/calculators/${c.slug}`}>{c.title}</a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <nav class="footer-nav" aria-label="정책">
          <a href="/privacy">개인정보처리방침</a>
          <span aria-hidden="true">·</span>
          <a href="/terms">이용약관</a>
        </nav>
        <p class="copyright">&copy; {year} 계산기 허브. All rights reserved.</p>
      </div>
    </footer>

    <style is:global>
      :root {
        --accent: #0d9488; /* teal */
        --accent-dark: #0f766e;
        --text: #1f2937;
        --text-muted: #6b7280;
        --bg: #ffffff;
        --bg-soft: #f3f4f6;
        --border: #e5e7eb;
        --radius: 12px;
        --maxw: 720px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
      }

      body {
        margin: 0;
        font-family: system-ui, 'Apple SD Gothic Neo', 'Malgun Gothic', sans-serif;
        color: var(--text);
        background: var(--bg);
        line-height: 1.6;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      .container {
        width: 100%;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0 16px;
      }

      main.container {
        flex: 1 0 auto;
        padding-top: 24px;
        padding-bottom: 48px;
      }

      a {
        color: var(--accent);
      }

      h1,
      h2,
      h3 {
        line-height: 1.3;
        color: var(--text);
      }

      /* Header */
      .site-header {
        border-bottom: 1px solid var(--border);
        background: var(--bg);
      }
      .header-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 8px 16px;
        padding-top: 12px;
        padding-bottom: 12px;
      }
      .brand {
        font-weight: 700;
        font-size: 1.15rem;
        color: var(--accent-dark);
        text-decoration: none;
      }
      .site-nav ul {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin: 0;
        padding: 0;
      }
      .site-nav a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
      }
      .site-nav a:hover {
        color: var(--accent);
      }

      /* Footer */
      .site-footer {
        border-top: 1px solid var(--border);
        background: var(--bg-soft);
        padding: 20px 0;
        margin-top: auto;
      }
      .footer-nav {
        display: flex;
        gap: 8px;
        justify-content: center;
        font-size: 0.9rem;
      }
      .footer-nav a {
        color: var(--text-muted);
        text-decoration: none;
      }
      .footer-nav a:hover {
        color: var(--accent);
      }
      .copyright {
        text-align: center;
        color: var(--text-muted);
        font-size: 0.8rem;
        margin: 8px 0 0;
      }

      /* Shared form / result styles used by calculator pages */
      .calc-form {
        display: grid;
        gap: 16px;
        background: var(--bg-soft);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        margin: 20px 0;
      }
      .calc-form label {
        display: grid;
        gap: 6px;
        font-weight: 600;
        font-size: 0.95rem;
      }
      .calc-form input {
        font: inherit;
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--bg);
        width: 100%;
      }
      .calc-form .hint {
        font-weight: 400;
        color: var(--text-muted);
        font-size: 0.8rem;
      }
      .btn {
        font: inherit;
        font-weight: 600;
        color: #fff;
        background: var(--accent);
        border: none;
        border-radius: 8px;
        padding: 12px 16px;
        cursor: pointer;
      }
      .btn:hover {
        background: var(--accent-dark);
      }

      .result-box {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        margin: 20px 0;
        background: var(--bg);
      }
      .result-grid {
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      }
      .result-item {
        background: var(--bg-soft);
        border-radius: 8px;
        padding: 12px;
        text-align: center;
      }
      .result-item .label {
        display: block;
        font-size: 0.85rem;
        color: var(--text-muted);
      }
      .result-item .value {
        display: block;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--accent-dark);
      }

      table.breakdown {
        width: 100%;
        border-collapse: collapse;
        margin-top: 12px;
        font-size: 0.95rem;
      }
      table.breakdown th,
      table.breakdown td {
        padding: 10px 8px;
        border-bottom: 1px solid var(--border);
        text-align: left;
      }
      table.breakdown td:last-child,
      table.breakdown th:last-child {
        text-align: right;
        font-variant-numeric: tabular-nums;
      }
      table.breakdown tr.total td {
        font-weight: 700;
        border-top: 2px solid var(--border);
      }

      .disclaimer {
        font-size: 0.85rem;
        color: var(--text-muted);
        background: #fffbeb;
        border: 1px solid #fde68a;
        border-radius: 8px;
        padding: 12px;
        margin: 16px 0;
      }
      .note {
        font-size: 0.9rem;
        color: var(--text-muted);
      }

      .faq h3 {
        font-size: 1rem;
        margin-bottom: 4px;
      }
      .faq details {
        border-bottom: 1px solid var(--border);
        padding: 10px 0;
      }
      .faq summary {
        cursor: pointer;
        font-weight: 600;
      }
      .faq p {
        margin: 8px 0 0;
        color: var(--text-muted);
        font-size: 0.95rem;
      }

      .hidden {
        display: none;
      }
    </style>
  </body>
</html>
