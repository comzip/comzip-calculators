---
import { categoryOrder, calculatorsByCategory, categoryLabels } from '../data/calculators';
import { ui, type Lang } from '../i18n/ui';

export interface Props {
  title: string;
  description?: string;
  /**
   * Locale-neutral path (no `/en` prefix), e.g. `/calculators/bmi-calculator`
   * or `/` for the home page. Used to build canonical / OG / hreflang URLs
   * for both locales.
   */
  path?: string;
  /** Page locale. Defaults to Korean, the site's default/unprefixed locale. */
  lang?: Lang;
}

const { title, description, path = '/', lang = 'ko' } = Astro.props;

const t = ui[lang];
const resolvedDescription = description ?? t.defaultDescription;
const siteName = t.siteName;
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;

// English pages live under `/en`; Korean is unprefixed at the site root.
const localePrefix = lang === 'en' ? '/en' : '';
const localizedPath = `${localePrefix}${path}`;

// Astro.site comes from `site` in astro.config.mjs.
const canonicalURL = Astro.site ? new URL(localizedPath, Astro.site).href : localizedPath;
const koPath = path;
const enPath = path === '/' ? '/en/' : `/en${path}`;
const koURL = Astro.site ? new URL(koPath, Astro.site).href : koPath;
const enURL = Astro.site ? new URL(enPath, Astro.site).href : enPath;
const langSwitchHref = lang === 'ko' ? enPath : koPath;
const year = new Date().getFullYear();

// TODO: replace with your real GA4 Measurement ID (from analytics.google.com).
// Left as a placeholder so no tracking script loads until you set a real ID.
const GA_MEASUREMENT_ID = 'G-0H2MTD7S3L';
const analyticsEnabled = GA_MEASUREMENT_ID !== 'G-XXXXXXXXXX';

// AdSense publisher ID (from adsense.google.com → 사이트 연결 코드).
const ADSENSE_CLIENT_ID = 'ca-pub-7827578660524156';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="google-site-verification" content="jbJG45GdqodGRlT0eFGqhDd7m7-Di2ukHq5dE4XAhY0" />

    <title>{fullTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="ko" href={koURL} />
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="x-default" href={koURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={lang === 'ko' ? 'ko_KR' : 'en_US'} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={resolvedDescription} />

    <meta name="google-adsense-account" content={ADSENSE_CLIENT_ID} />
    <script
      async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT_ID}`}
      crossorigin="anonymous"
    />

    {
      analyticsEnabled && (
        <>
          <script
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
          />
          <script define:vars={{ GA_MEASUREMENT_ID }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag('js', new Date());
            gtag('config', GA_MEASUREMENT_ID);
          </script>
        </>
      )
    }
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href={localePrefix || '/'} class="brand">{siteName}</a>
        <nav class="site-nav" aria-label={t.navLabel}>
          {
            categoryOrder.map((category) => (
              <details class="nav-dropdown">
                <summary>{categoryLabels[category][lang]}</summary>
                <ul>
                  {calculatorsByCategory(category).map((c) => (
                    <li>
                      <a href={`${localePrefix}/calculators/${c.slug}`}>
                        {lang === 'en' ? c.titleEn : c.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            ))
          }
        </nav>
        <a href={langSwitchHref} class="lang-switch" hreflang={lang === 'ko' ? 'en' : 'ko'}>
          {t.langSwitchLabel}
        </a>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <nav class="footer-nav" aria-label={t.policyLabel}>
          <a href={`${localePrefix}/privacy`}>{t.privacy}</a>
          <span aria-hidden="true">·</span>
          <a href={`${localePrefix}/terms`}>{t.terms}</a>
        </nav>
        <p class="copyright">&copy; {year} {siteName}. All rights reserved.</p>
      </div>
    </footer>

    <style is:global>
      :root {
        --accent: #0d9488; /* teal */
        --accent-dark: #0f766e;
        --text: #1f2937;
        --text-muted: #6b7280;
        --bg: #ffffff;
        --bg-soft: #f3f4f6;
        --border: #e5e7eb;
        --radius: 12px;
        --maxw: 720px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
        overflow-x: hidden;
      }

      body {
        margin: 0;
        font-family: system-ui, 'Apple SD Gothic Neo', 'Malgun Gothic', sans-serif;
        color: var(--text);
        background: var(--bg);
        line-height: 1.6;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        /* Safety net: nothing (dropdown panels, wide tables, etc.) should be
           able to grow the page's horizontal scroll area and leave blank
           space beside the content. */
        overflow-x: hidden;
      }

      .container {
        width: 100%;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0 16px;
      }

      main.container {
        flex: 1 0 auto;
        padding-top: 24px;
        padding-bottom: 48px;
      }

      a {
        color: var(--accent);
      }

      h1,
      h2,
      h3 {
        line-height: 1.3;
        color: var(--text);
      }

      /* Header */
      .site-header {
        border-bottom: 1px solid var(--border);
        background: var(--bg);
      }
      .header-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 8px 16px;
        padding-top: 12px;
        padding-bottom: 12px;
      }
      .brand {
        font-weight: 700;
        font-size: 1.15rem;
        color: var(--accent-dark);
        text-decoration: none;
      }
      .site-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 4px 8px;
      }
      .lang-switch {
        padding: 6px 10px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-muted);
        text-decoration: none;
        white-space: nowrap;
      }
      .lang-switch:hover {
        color: var(--accent);
        background: var(--bg-soft);
      }
      .nav-dropdown {
        position: relative;
      }
      .nav-dropdown > summary {
        list-style: none;
        cursor: pointer;
        padding: 6px 10px;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text-muted);
        white-space: nowrap;
        user-select: none;
      }
      /* Hide the native disclosure triangle across engines. */
      .nav-dropdown > summary::-webkit-details-marker {
        display: none;
      }
      .nav-dropdown > summary::after {
        content: '▾';
        font-size: 0.7em;
        margin-left: 5px;
        color: var(--text-muted);
      }
      .nav-dropdown > summary:hover {
        color: var(--accent);
        background: var(--bg-soft);
      }
      .nav-dropdown[open] > summary {
        color: var(--accent);
        background: var(--bg-soft);
      }
      .nav-dropdown[open] > summary::after {
        content: '▴';
      }
      .nav-dropdown > ul {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        z-index: 20;
        list-style: none;
        margin: 0;
        padding: 6px;
        min-width: 180px;
        max-width: calc(100vw - 32px);
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
      }
      /* Applied by script below at open-time when the panel would overflow
         the right edge of the viewport, regardless of which category or how
         many there are. */
      .nav-dropdown.flip-left > ul {
        left: auto;
        right: 0;
      }
      .nav-dropdown > ul li {
        margin: 0;
      }
      .nav-dropdown > ul a {
        display: block;
        padding: 8px 10px;
        border-radius: 8px;
        color: var(--text);
        text-decoration: none;
        font-size: 0.9rem;
        white-space: nowrap;
      }
      .nav-dropdown > ul a:hover {
        color: var(--accent);
        background: var(--bg-soft);
      }

      @media (max-width: 480px) {
        .header-inner {
          gap: 8px;
        }
        .site-nav {
          gap: 2px 4px;
        }
        .nav-dropdown > summary {
          padding: 6px 8px;
          font-size: 0.85rem;
        }
      }

      /* Footer */
      .site-footer {
        border-top: 1px solid var(--border);
        background: var(--bg-soft);
        padding: 20px 0;
        margin-top: auto;
      }
      .footer-nav {
        display: flex;
        gap: 8px;
        justify-content: center;
        font-size: 0.9rem;
      }
      .footer-nav a {
        color: var(--text-muted);
        text-decoration: none;
      }
      .footer-nav a:hover {
        color: var(--accent);
      }
      .copyright {
        text-align: center;
        color: var(--text-muted);
        font-size: 0.8rem;
        margin: 8px 0 0;
      }

      /* Shared form / result styles used by calculator pages */
      .calc-form {
        display: grid;
        gap: 16px;
        background: var(--bg-soft);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        margin: 20px 0;
      }
      .calc-form label {
        display: grid;
        gap: 6px;
        font-weight: 600;
        font-size: 0.95rem;
      }
      .calc-form input,
      .calc-form select {
        font: inherit;
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--bg);
        width: 100%;
      }
      .calc-form .hint {
        font-weight: 400;
        color: var(--text-muted);
        font-size: 0.8rem;
      }
      .amount-preview {
        font-weight: 500;
        font-size: 0.85rem;
        color: var(--accent-dark);
        margin-top: 4px;
        min-height: 1.2em;
      }
      /* Shared by calculators that offer a small set of mutually exclusive
         options (repayment method, taxable-asset type, property type, ...). */
      .method-toggle {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 12px;
        margin: 0;
      }
      .method-toggle legend {
        font-weight: 600;
        font-size: 0.95rem;
        padding: 0 4px;
      }
      /* `.calc-form label` below sets display:grid at specificity (0,1,1);
         a bare `.method-option`/`.check-row` class (0,1,0) would lose that
         fight, so these are qualified with `.calc-form` to win at (0,2,0)
         regardless of how deeply they're nested inside the form. */
      .calc-form .method-option {
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 500;
        cursor: pointer;
      }
      .calc-form .method-option input {
        width: auto;
        margin: 0;
      }
      /* Shared checkbox-plus-label row (e.g. "1세대 1주택입니다"). */
      .calc-form .check-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        font-weight: 500;
      }
      .calc-form .check-row input {
        width: auto;
        margin: 0;
        order: 1;
        flex-shrink: 0;
      }
      .btn {
        font: inherit;
        font-weight: 600;
        color: #fff;
        background: var(--accent);
        border: none;
        border-radius: 8px;
        padding: 12px 16px;
        cursor: pointer;
      }
      .btn:hover {
        background: var(--accent-dark);
      }

      .result-box {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        margin: 20px 0;
        background: var(--bg);
      }
      .result-grid {
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      }
      .result-item {
        background: var(--bg-soft);
        border-radius: 8px;
        padding: 12px;
        text-align: center;
      }
      .result-item .label {
        display: block;
        font-size: 0.85rem;
        color: var(--text-muted);
      }
      .result-item .value {
        display: block;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--accent-dark);
      }

      table.breakdown {
        width: 100%;
        border-collapse: collapse;
        margin-top: 12px;
        font-size: 0.95rem;
      }
      table.breakdown th,
      table.breakdown td {
        padding: 10px 8px;
        border-bottom: 1px solid var(--border);
        text-align: left;
      }
      table.breakdown td:last-child,
      table.breakdown th:last-child {
        text-align: right;
        font-variant-numeric: tabular-nums;
      }
      table.breakdown tr.total td {
        font-weight: 700;
        border-top: 2px solid var(--border);
      }

      .disclaimer {
        font-size: 0.85rem;
        color: var(--text-muted);
        background: #fffbeb;
        border: 1px solid #fde68a;
        border-radius: 8px;
        padding: 12px;
        margin: 16px 0;
      }
      .note {
        font-size: 0.9rem;
        color: var(--text-muted);
      }

      .faq h3 {
        font-size: 1rem;
        margin-bottom: 4px;
      }
      .faq details {
        border-bottom: 1px solid var(--border);
        padding: 10px 0;
      }
      .faq summary {
        cursor: pointer;
        font-weight: 600;
      }
      .faq p {
        margin: 8px 0 0;
        color: var(--text-muted);
        font-size: 0.95rem;
      }

      .hidden {
        display: none;
      }
    </style>

    <script>
      // Header nav dropdown behavior: only one open at a time, close on
      // outside click, close on Escape.
      const dropdowns = Array.from(
        document.querySelectorAll<HTMLDetailsElement>('.nav-dropdown')
      );

      dropdowns.forEach((dropdown) => {
        const panel = dropdown.querySelector('ul');
        dropdown.addEventListener('toggle', () => {
          if (!dropdown.open) return;
          dropdowns.forEach((other) => {
            if (other !== dropdown) other.open = false;
          });

          // Open leftward instead of rightward if the panel would overflow
          // the viewport's right edge. Measured at open-time so it works
          // regardless of category count/order or viewport width, instead
          // of assuming a fixed trigger is the one near the edge.
          dropdown.classList.remove('flip-left');
          if (panel && panel.getBoundingClientRect().right > window.innerWidth) {
            dropdown.classList.add('flip-left');
          }
        });
      });

      document.addEventListener('click', (event) => {
        const target = event.target as Node;
        dropdowns.forEach((dropdown) => {
          if (dropdown.open && !dropdown.contains(target)) {
            dropdown.open = false;
          }
        });
      });

      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        dropdowns.forEach((dropdown) => {
          if (dropdown.open) {
            dropdown.open = false;
            dropdown.querySelector('summary')?.focus();
          }
        });
      });
    </script>
  </body>
</html>
